# ============================================================
# CrowdSync | .gitignore
# ============================================================

# ── Terraform ───────────────────────────────────────────────
# Local state (real state lives in S3 backend)
terraform.tfstate
terraform.tfstate.backup

# Downloaded providers — large, always regenerated by tf init
.terraform/

# Saved plan files — binary, machine-specific
tfplan
*.tfplan

# Terraform variable files — may contain secrets
*.tfvars
*.tfvars.json

# Note: .terraform.lock.hcl IS committed (ensures consistent provider versions)

# ── Lambda Build Artifacts ───────────────────────────────────
# Compiled ZIPs are regenerated by Terraform automatically
modules/lambda/*.zip

# Python bytecode
__pycache__/
*.py[cod]
*.pyo

# ── Debug / Scratch Files ────────────────────────────────────
debug.js
get_logs.py
cognito_test.js
output.json

# ── UI / Node ────────────────────────────────────────────────
dashboard/node_modules/
dashboard/dist/
dashboard/dist-ssr/
dashboard/*.local

# ── macOS ────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Editor ───────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.sw?
